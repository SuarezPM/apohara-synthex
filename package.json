{
  "name": "@apohara/synthex",
  "version": "0.6.0-rc.0",
  "description": "The JavaScript layer that turns brightdata-mcp into an intelligence & evidence platform: classify what your agents scrape and seal it verifiably (HMAC-SHA256 + RFC 3161 TSA). v4: two-layer pre-LLM defense (28 web-injection + 78 prompt-level deterministic rules) + decisions[] audit trail + canonicalize HMAC.",
  "type": "module",
  "bin": {
    "apohara-synthex": "./server.js",
    "synthex": "bin/synthex.mjs",
    "decode-evidence": "bin/decode-evidence.js"
  },
  "main": "./server.js",
  "files": [
    "bin/",
    "src/",
    "demo/",
    "scripts/gen-sample-report.mjs",
    "scripts/measure-coverage.mjs",
    "server.js",
    "SLIDES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SuarezPM/apohara-synthex.git"
  },
  "homepage": "https://synthex.apohara.dev",
  "bugs": {
    "url": "https://github.com/SuarezPM/apohara-synthex/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test",
    "demo": "node demo/demo.js",
    "cli": "node bin/synthex.mjs",
    "sample": "node scripts/gen-sample-report.mjs",
    "bench:djl": "node test/djl-latency.bench.js",
    "start": "node server.js"
  },
  "keywords": [
    "mcp",
    "bright-data",
    "web-data",
    "evidence",
    "rfc3161",
    "agent-observability"
  ],
  "license": "MIT",
  "author": "Pablo M. Suárez (@SuarezPM)",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.21.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "asn1js": "^3.0.5",
    "fastmcp": "^3.33.0",
    "pdfkit": "^0.18.0",
    "pkijs": "^3.0.15",
    "playwright": "^1.60.0",
    "pvutils": "^1.1.3",
    "qrcode": "^1.5.4",
    "zod": "^3.23.0"
  }
}
